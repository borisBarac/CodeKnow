# LangChain embedding provider defaults
# Copy this file to .env and uncomment/edit as needed.

# Embedding provider: "ollama" or "openrouter"
EMBEDDING_PROVIDER=ollama
# Embedding model name (ollama default: nomic-embed-text)
EMBEDDING_MODEL=qwen3-embedding:4b

# OLLAMA_BASE_URL=http://localhost:11434/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v2
# OPENROUTER_API_KEY=

# Pipeline paths — defaults are relative to cwd if unset
# CODEKNOW_INPUT_DIR=.codeknow/repos
# CODEKNOW_OUTPUT_DIR=codeknow-out
