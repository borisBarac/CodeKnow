EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:4b

OLLAMA_BASE_URL=http://localhost:11434/v1

CHROMA_HOST=localhost
CHROMA_PORT=8018

# LLM Judge (evaluates hybrid search quality)
# Set OPENROUTER_API_KEY in e2e/.env.e2e.local or as an env var.
# See e2e/README.md for local override instructions.
JUDGE_LLM_MODEL=deepseek/deepseek-v4-pro
JUDGE_LLM_BASE_URL=https://openrouter.ai/api/v1
