EMBEDDING_PROVIDER=docker
EMBEDDING_MODEL=ai/qwen3-embedding:4B

DOCKER_MODEL_RUNNER_URL=http://localhost:12434/engines/v1

CHROMA_HOST=localhost
CHROMA_PORT=8018

